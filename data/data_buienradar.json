ther/96x96/B.png","graphUrl":"https://www.buienradar.nl/nederland/weerbericht/weergrafieken/b","temperature":10.5,"groundtemperature":11.9,"humidity":63.0,"precipitation":0.0,"sunpower":719.0,"rainFallLast24Hour":0.6,"rainFallLastHour":0.0},{"$id":"41","stationid":6340,"stationname":"Meetstation Woensdrecht","lat":51.45,"lon":4.33,"regio":"Woensdrecht","timestamp":"2026-05-11T12:50:00","weatherdescription":"Zwaar bewolkt","iconurl":"https://cdn.buienradar.nl/resources/images/icons/weather/30x30/c.png","fullIconUrl":"https://cdn.buienradar.nl/resources/images/icons/weather/96x96/C.png","graphUrl":"https://www.buienradar.nl/nederland/weerbericht/weergrafieken/c","winddirection":"WNW","airpressure":1007.4,"temperature":10.2,"groundtemperature":10.7,"feeltemperature":7.5,"visibility":43800.0,"windgusts":10.0,"windspeed":5.8,"windspeedBft":4,"humidity":64.0,"precipitation":0.0,"rainFallLast24Hour":1.0,"rainFallLastHour":0.0,"winddirectiondegrees":296},{"$id":"42","stationid":6239,"stationname":"Meetstation Zeeplatform F-3","lat":54.85,"lon":4.73,"regio":"Noordzee","timestamp":"2026-05-11T12:50:00","weatherdescription":"Zwaar bewolkt","iconurl":"https://cdn.buienradar.nl/resources/images/icons/weather/30x30/c.png","fullIconUrl":"https://cdn.buienradar.nl/resources/images/icons/weather/96x96/C.png","graphUrl":"https://www.buienradar.nl/nederland/weerbericht/weergrafieken/c","winddirection":"NW","airpressure":1000.6,"temperature":5.7,"feeltemperature":-1.1,"visibility":9050.0,"windgusts":20.9,"windspeed":18.0,"windspeedBft":8,"humidity":83.0,"winddirectiondegrees":314}]},"forecast":{"$id":"43","weatherreport":{"$id":"44","published":"2026-05-11T11:45:00","title":"Koud en vanavond in het noorden onstuimig","summary":"De lente zit de komende dagen duidelijk in een dip, met lage temperaturen en wisselvallig weer. Vandaag valt er tijdelijk regen en vanavond wordt het in het noordelijk kustgebied zelfs onstuimig.","text":"De lente zit de komende dagen duidelijk in een dip, met lage temperaturen en wisselvallig weer. Vandaag valt er tijdelijk regen en vanavond wordt het in het noordelijk kustgebied zelfs onstuimig.Vanmiddag trekt een smal gebied met regen van noordwest naar zuidoost over het land. Voor de regen uit is de zon geregeld zichtbaar, terwijl achter het neerslaggebied opnieuw af en toe zon voorkomt, vooral in combinatie met enkele buien in het noorden. Het&nbsp;is een ronduit koude dag voor de tijd van het jaar, met maximumtemperaturen van slechts ongeveer 12 graden. De noordwestenwind is matig en aan zee vrij krachtig tot krachtig. In het noordelijk kustgebied neemt de wind verder toe tot hard, windkracht 7. Aan het einde van de middag zijn daar en op het IJsselmeer windstoten mogelijk tot circa 75 km/u.Vanavond wordt het in het noordelijk kustgebied ronduit onstuimig, met een harde tot stormachtige noordwestenwind (windkracht 7 tot 8) en kans op zware windstoten tot 90 km/u. Verder is er af en toe zon en trekken verspreid enkele buien over het land. Later op de avond komen de meeste buien in de noordelijke helft voor, mogelijk vergezeld van onweer. Vannacht wisselen opklaringen en wolkenvelden elkaar af en trekken de buien geleidelijk naar het noordoosten en oosten weg. Elders wordt het droog. De temperatuur daalt naar ongeveer 6 graden aan zee en lokaal 2 graden rond de Veluwe. Langs de kust staat een vrij krachtige tot krachtige wind; in het noordelijk kustgebied is de wind aanvankelijk nog hard (windkracht 5 tot 7).Morgen zijn er perioden met zon en blijft het overdag droog. In de middag neemt vanuit het westen de bewolking toe en in de avond trekt verspreid wat regen over het land. De maximumtemperatuur varieert van ongeveer 12 graden in het noorden tot 14 graden in het zuidoosten. Daarmee blijft het fris voor de tijd van het jaar. De wind waait matig en langs de kust matig tot vrij krachtig uit westelijke richtingen.De dagen daarna blijft het de rest van de werkweek uitgesproken fris. Er is af en toe zon, maar er vallen ook buien, mogelijk met onweer en plaatselijk korrelhagel. Omdat het om buien gaat, kunnen de weersverschillen van plaats tot plaats groot zijn en wordt de neerslag ongelijk verdeeld. De middagtemperatuur ligt rond een koude 13 graden. In het weekend blijft het naar verwachting op de meeste plaatsen droog met af en toe zon. De temperatuur loopt dan geleidelijk weer op naar ongeveer 15 graden op zaterdag en 16 tot 18 graden op zondag.","author":"Marc de Jong","authorbio":"Sinds 2019 actief als meteoroloog bij Buienradar."},"shortterm":{"$id":"45","startdate":"2026-05-12T00:00:00","enddate":"2026-05-16T00:00:00","forecast":"Eerst wisselvallig en vrij koel met enkele buien. In het weekeinde vrijwel overal droog met af en toe zon en hogere temperaturen."},"longterm":{"$id":"46","startdate":"2026-05-17T00:00:00","enddate":"2026-05-21T00:00:00","forecast":"Perioden met zon. De dagelijkse neerslagkans is ongeveer 30%. De kans op temperaturen boven het langjarig gemiddelde neemt toe naar ongeveer 60%."},"fivedayforecast":[{"$id":"47","day":"2026-05-11T00:00:00","mintemperature":"7","maxtemperature":"11","mintemperatureMax":7,"mintemperatureMin":7,"maxtemperatureMax":11,"maxtemperatureMin":11,"rainChance":60,"sunChance":30,"windDirection":"nw","wind":4,"mmRainMin":2.0,"mmRainMax":2.0,"weatherdescription":"Afwisselend bewolkt met (mogelijk) wat lichte regen","iconurl":"https://cdn.buienradar.nl/resources/images/icons/weather/30x30/f.png","fullIconUrl":"https://cdn.buienradar.nl/resources/images/icons/weather/96x96/F.png"},{"$id":"48","day":"2026-05-12T00:00:00","mintemperature":"6","maxtemperature":"13","mintemperatureMax":6,"mintemperatureMin":6,"maxtemperatureMax":13,"maxtemperatureMin":13,"rainChance":60,"sunChance":30,"windDirection":"w","wind":4,"mmRainMin":1.0,"mmRainMax":1.0,"weatherdescription":"Afwisselend bewolkt met (mogelijk) wat lichte regen","iconurl":"https://cdn.buienradar.nl/resources/images/icons/weather/30x30/f.png","fullIconUrl":"https://cdn.buienradar.nl/res