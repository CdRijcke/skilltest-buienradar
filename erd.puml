@startuml

entity WeatherStations {
    * stationid : int <<PK>>
    --
    stationname : str
    lat : float
    lon : float
    regio : str
}

entity StationMeasurement {
    * measurementid : UUID <<PK>>
    --
    * stationid : int <<FK>>
    timestamp : datetime
    temperature : float
    groundtemperature : float
    feeltemperature : float
    windgusts : float
    windspeedBft : float
    humidity : float
    precipitation : float
    sunpower : float
}

WeatherStations ||--o{ StationMeasurement : "stationid"

@enduml
